# LOCAL SETUP: Copy this file to `.env.local` in the SAME folder as `package.json`, then fill in values.
#   PowerShell: Copy-Item .env.example .env.local
#   macOS/Linux: cp .env.example .env.local
# Without `.env.local`, Google auth and NextAuth will not work on your machine. Never commit `.env.local`.
#
# Google Web client — paste from JSON, or run: npm run env:sync-google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Cloud Console → Credentials → your OAuth 2.0 Client ID (type: Web application).
# Add every origin you use (localhost, ngrok, custom domain) in BOTH places:
#   Authorized JavaScript origins: <origin>
#   Authorized redirect URIs:      <origin>/api/auth/callback/google
# Examples:
#   http://localhost:3000
#   https://your-ngrok-subdomain.ngrok-free.app

# Random secret (required). Windows: npm run env:nextauth-secret   (or: openssl rand -base64 32 if installed)
NEXTAUTH_SECRET=

# Optional: force a fixed auth origin (no trailing slash).
# If omitted, auth origin is resolved dynamically from incoming host (recommended for localhost + ngrok switching).
# NEXTAUTH_URL=http://localhost:3000

# Gemini API key used by /api/business-lookup. Keep server-only.
GEMINI_API_KEY=

# Optional Gemini model override (defaults to gemini-2.5-flash in code).
# Used by lookup + selected-profile follow-up chat endpoints.
# Use model IDs only (example: gemini-2.5-flash). Do NOT prefix with "models/".
GEMINI_MODEL=gemini-2.5-flash

# Prisma SQLite database path (used for saved profiles + per-profile chat history)
DATABASE_URL="file:./prisma/dev.db"
